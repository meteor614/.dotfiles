#!/bin/bash
# fzsession — fuzzy-switch between multiplexer sessions
# Priority: zellij > tmux
set -euo pipefail

have_cmd() { command -v "$1" >/dev/null 2>&1; }

# Strip ANSI escape codes (color, style) from multiplexer session listings
strip_ansi() { sed $'s/\e\[[0-9;]*[a-zA-Z]//g'; }

if have_cmd zellij; then
    sessions=$(zellij list-sessions 2>/dev/null | strip_ansi || true)
    if [ -n "$sessions" ]; then
        chosen=$(printf '%s\n' "$sessions" | fzf --header="Zellij sessions" --prompt="attach > " 2>/dev/null || true)
        if [ -n "$chosen" ]; then
            name=$(printf '%s\n' "$chosen" | awk '{print $1}')
            exec zellij attach "$name"
        fi
    fi
fi

if have_cmd tmux; then
    sessions=$(tmux list-sessions 2>/dev/null | strip_ansi || true)
    if [ -n "$sessions" ]; then
        chosen=$(printf '%s\n' "$sessions" | fzf --header="tmux sessions" --prompt="attach > " 2>/dev/null || true)
        if [ -n "$chosen" ]; then
            name=$(printf '%s\n' "$chosen" | awk -F: '{print $1}')
            exec tmux attach-session -t "$name"
        fi
    fi
fi

echo "fzsession: no multiplexer sessions found" >&2
exit 1
