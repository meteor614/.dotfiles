{
  "_comment": "CodeBuddy ‚Üí herdr agent state hooks. Custom (not herdr's official claude integration) so we can label panes 'codebuddy' instead of 'claude' and map Stop to 'blocked' (waiting for user input) instead of 'idle'. Other lifecycle map: SessionStart‚Üíidle, PreToolUse/UserPromptSubmit/PostToolUse‚Üíworking, PermissionRequest‚Üíblocked, SessionEnd‚Üírelease.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.codebuddy/hooks/herdr-agent-state.sh idle", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.codebuddy/hooks/herdr-agent-state.sh working", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.codebuddy/hooks/herdr-agent-state.sh working", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.codebuddy/hooks/herdr-agent-state.sh working", "timeout": 10 }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.codebuddy/hooks/herdr-agent-state.sh blocked", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.codebuddy/hooks/herdr-agent-state.sh blocked", "timeout": 10 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.codebuddy/hooks/herdr-agent-state.sh release", "timeout": 10 }
        ]
      }
    ]
  }
}
