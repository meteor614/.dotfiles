{
  "_comment": "claude-internal → herdr agent state hooks. Custom (not herdr's official claude integration) so we can label panes 'claude-internal' instead of 'claude' to distinguish from the public claude.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude-internal/hooks/herdr-agent-state.sh idle", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude-internal/hooks/herdr-agent-state.sh working", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude-internal/hooks/herdr-agent-state.sh working", "timeout": 10 }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude-internal/hooks/herdr-agent-state.sh blocked", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude-internal/hooks/herdr-agent-state.sh idle", "timeout": 10 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude-internal/hooks/herdr-agent-state.sh release", "timeout": 10 }
        ]
      }
    ]
  }
}
