# 优化后的 vpy/vpip 函数
vpy() {
    local python="${PWD}/.venv/bin/python3"
    [[ -x "$python" ]] || python="python3"
    "$python" "$@"
}
vpip() {
    local pip="${PWD}/.venv/bin/pip3"
    [[ -x "$pip" ]] || pip="pip3"
    "$pip" "$@"
}
