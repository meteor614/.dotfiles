# start tmux if ssh
if (( $+commands[tmux] )) && [[ -z "${DOTFILES_NONINTERACTIVE:-}" && -n "$SSH_CONNECTION" && -z "$TMUX" && -t 0 && $# -eq 0 && -z "${ZSH_EXECUTION_STRING:-}" ]]; then
    tmux new -As default-0
